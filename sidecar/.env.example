# === Required ===
PORT=8789

# === Google Apps Script (GAS) ===
# URL to your deployed GAS web app for sheet diagnostics
GAS_DIAG_URL=
# HTTP method for GAS requests (POST or GET)
GAS_METHOD=POST
# Timeout for GAS requests in ms
GAS_TIMEOUT_MS=60000

# === LLM (Optional — enables coach mode) ===
# OpenAI API key (sk-...). If not set, falls back to deterministic rules-only summaries.
LLM_API_KEY=
LLM_API_URL=https://api.openai.com
LLM_MODEL=gpt-4o
LLM_FALLBACK_MODEL=gpt-4o
LLM_TIMEOUT_MS=180000
LLM_MAX_TOKENS=3000
REASON_BUDGET_TOKENS=2000
HUMANIZED_MIN_CHARS=600
# Optional org/project headers (aliases: LLM_PROJECT_ID, OPENAI_ORGANIZATION)
OPENAI_PROJECT=
OPENAI_ORG=

# === TTS (Optional) ===
# Provider: edge (free, default), azure, openai, google
TTS_PROVIDER=edge

# Edge TTS (free, no API key needed)
EDGE_VOICE=en-US-AriaNeural
EDGE_RATE=+0%
EDGE_VOLUME=+0%

# Azure TTS (requires subscription key)
AZURE_TTS_KEY=
AZURE_TTS_REGION=eastus
AZURE_TTS_VOICE=en-US-OnyxMultilingualNeural
AZURE_TTS_RATE=+15%
AZURE_TTS_PITCH=0%
AZURE_TTS_VOLUME=0%

# OpenAI TTS (uses LLM_API_KEY)
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_FORMAT=mp3

# === CORS (Optional) ===
# Comma-separated allowed origins. Empty = allow all (dev only).
CORS_ORIGIN=
