{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "rootDir": "srv",
    "outDir": "dist",
    "types": ["node"]
  },
  "include": ["srv"]
}
